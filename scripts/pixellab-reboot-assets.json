{
  "version": 1,
  "objective": "Regenerate the complete Politicmon presentation layer in PixelLab while preserving gameplay logic, map data, battle math, saves, quests, and multiplayer.",
  "style": {
    "direction": "cozy 3/4 RPG pixel art, Stardew-like readability, Italian political satire, soft natural palette, no neon terrain, consistent outline weight",
    "canvas": "240x180 internal resolution, 16px world tile, pixel-perfect nearest-neighbor scaling",
    "viewRules": [
      "Moving directional actors use 4 cardinal views plus walking frames.",
      "Static objects use one transparent view unless they are entered, boarded, or direction-sensitive.",
      "Terrain transitions use PixelLab Wang tilesets, not one-off noisy tile swaps.",
      "Text remains bitmap font; all frames, chips, icons, panels, props, terrain, actors, monsters, and battle backdrops come from PixelLab."
    ]
  },
  "mcp": {
    "server": "pixellab",
    "docs": "https://api.pixellab.ai/mcp/docs",
    "note": "Use MCP tools directly after Codex restart. Do not use REST creation endpoints from scripts; direct HTTP is only for public download URLs returned by MCP."
  },
